  "item": [
    {
      "name": "Consulta cep valido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200 e resposta deve conter a  localidade esperada\", function () {\r",
              "    let expectedLocalidade = pm.variables.get(\"localidade\");\r",
              "    pm.response.to.have.status(200);\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"localidade\", expectedLocalidade);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://viacep.com.br/ws/{{cep}}/json/",
          "protocol": "https",
          "host": [
            "viacep",
            "com",
            "br"
          ],
          "path": [
            "ws",
            "{{cep}}",
            "json",
            ""
          ]
        },
        "description": "Scenario: Consultar cep válido\n\nGiven que eu possuo o CEP \"45989479\"  \nWhen eu faço uma requisição GET para /ws/45989479/json/  \nThen o status da resposta deve ser 200  \nAnd o campo \"localidade\" deve ser \"Teixeira de Freitas\""
      },
      "response": []
    },
    {
      "name": "Consulta por endereço",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200 e resposta deve conter a localidade 'Teixeira de Freitas'\", function () {\r",
              "    let expectedLocalidade = pm.variables.get(\"localidade\");\r",
              "    pm.response.to.have.status(200);\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"localidade\", expectedLocalidade);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://viacep.com.br/ws/ba/teixeira de freitas/Rua Abaete/json/",
          "protocol": "https",
          "host": [
            "viacep",
            "com",
            "br"
          ],
          "path": [
            "ws",
            "ba",
            "teixeira de freitas",
            "Rua Abaete",
            "json",
            ""
          ]
        },
        "description": "Scenario: Consultar por endereço\n\nGiven que desejo realizar consulta por endereço  \nWhen eu faço uma requisição GET para /ws/ba/teixeira de freitas/Rua Abaete/json/  \nThen o status da resposta deve ser 200  \nAnd resposta deve ser um array  \nAnd deve conter a localidade \"Teixeira de Freitas\""
      },
      "response": []
    },
    {
      "name": "Consulta cep invalido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Campo 'erro' presente\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(jsonData).to.have.property(\"erro\", \"true\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://viacep.com.br/ws/{{cepInvalido}}/json/",
          "protocol": "https",
          "host": [
            "viacep",
            "com",
            "br"
          ],
          "path": [
            "ws",
            "{{cepInvalido}}",
            "json",
            ""
          ]
        },
        "description": "Scenario: Consultar CEP inválido\n\nGiven que eu possuo o CEP \"00000000\"  \nWhen eu faço uma requisição GET para /ws/00000000/json/  \nThen o status da resposta deve ser 200  \nAnd campo \"erro\" deve estar presente com valor \"true\""
      },
      "response": []
    }
